function Projects() {
  const [query, setQuery] = useState("");
  const results = useMemo(() => {
    if (!query) return PROJECTS;
    const q = query.toLowerCase();
    return PROJECTS.filter((p) => p.title.toLowerCase().includes(q) || p.tags.join(" ").toLowerCase().includes(q));
  }, [query]);

  return (
    <section id="projects" className="max-w-6xl mx-auto px-6 py-16">
      <div className="flex items-end justify-between gap-6 mb-6">
        <div>
          <h2 className="text-2xl md:text-3xl font-semibold tracking-tight">Projects</h2>
          <p className="opacity-70 mt-2 max-w-xl">Long-form stories and series. Replace covers and copy with your own.</p>
        </div>
        <div className="w-56"><Input placeholder="Search projects…" value={query} onChange={(e) => setQuery(e.target.value)} /></div>
      </div>
      <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {results.map((p) => (
          <Card key={p.slug} className="overflow-hidden group">
            <a href={`#${p.slug}`}>
              <div className="aspect-[4/3] w-full overflow-hidden">
                <img src={p.cover} alt={p.title} className="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <CardContent className="p-4">
                <h3 className="font-medium">{p.title}</h3>
                <p className="text-sm opacity-70 mt-1">{p.desc}</p>
                <div className="flex flex-wrap gap-2 mt-3">
                  {p.tags.map((t) => (
                    <span key={t} className="text-xs px-2 py-1 rounded-full border bg-muted/30">{t}</span>
                  ))}
                </div>
              </CardContent>
            </a>
          </Card>
        ))}
      </div>
    </section>
  );
}

function Prints({ addToCart }) {
  const [selectedSize, setSelectedSize] = useState({});
  const choose = (id) => selectedSize[id] || Object.keys(PRINTS.find((p) => p.id === id).prices)[0];

  return (
    <section id="prints" className="bg-muted/30 border-y">
      <div className="max-w-6xl mx-auto px-6 py-16">
        <div className="flex items-end justify-between gap-6 mb-6">
          <div>
            <h2 className="text-2xl md:text-3xl font-semibold tracking-tight">Prints</h2>
            <p className="opacity-70 mt-2 max-w-2xl">Archival pigment prints, signed. Select a size and add to cart. Hook real checkout via Snipcart, Lemon Squeezy, Shopify Buy Button, or PayPal later.</p>
          </div>
        </div>
        <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {PRINTS.map((p) => (
            <Card key={p.id} className="overflow-hidden group">
              <div className="aspect-[3/4] w-full overflow-hidden bg-white">
                <img src={p.img} alt={p.title} className="h-full w-full object-cover" loading="lazy" />
              </div>
              <CardContent className="p-4 space-y-3">
                <div className="flex items-center justify-between">
                  <h3 className="font-medium">{p.title}</h3>
                  <span className="text-sm opacity-70">{p.edition}</span>
                </div>
                <div className="text-sm opacity-80">{p.paper}</div>
                <div className="flex items-center gap-3">
                  <Select onValueChange={(v) => setSelectedSize((s) => ({ ...s, [p.id]: v }))}>
                    <SelectTrigger className="w-28"><SelectValue placeholder={choose(p.id)} /></SelectTrigger>
                    <SelectContent>
                      {Object.keys(p.prices).map((size) => (
                        <SelectItem value={size} key={size}>{size} — {fmt(p.prices[size])}</SelectItem>
                      ))}
                    </SelectContent>
                  </Select>
                  <Button className="rounded-2xl" onClick={() => addToCart({
                    id: `${p.id}-${choose(p.id)}`,
                    title: `${p.title} (${choose(p.id)})`,
                    price: p.prices[choose(p.id)],
                    img: p.img,
                    meta: { size: choose(p.id) },
                  })}>Add to cart</Button>
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>
  );
}

