function Cart({ items, remove, clear }) {
  const total = items.reduce((s, it) => s + it.price * (it.qty || 1), 0);
  return (
    <section id="cart" className="max-w-6xl mx-auto px-6 py-12">
      <div className="flex items-center justify-between mb-4">
        <h2 className="text-xl md:text-2xl font-semibold tracking-tight">Cart</h2>
        {items.length > 0 && (
          <Button variant="outline" onClick={clear}>Clear</Button>
        )}
      </div>
      {items.length === 0 ? (
        <p className="opacity-70">Your cart is empty.</p>
      ) : (
        <div className="space-y-4">
          {items.map((it) => (
            <div key={it.id} className="flex items-center gap-4 border rounded-xl p-3">
              <img src={it.img} alt={it.title} className="w-16 h-16 object-cover rounded" />
              <div className="flex-1">
                <div className="font-medium">{it.title}</div>
                <div className="text-sm opacity-70">{it.meta?.size}</div>
              </div>
              <div className="text-sm">{fmt(it.price)}</div>
              <button onClick={() => remove(it.id)} className="p-2 hover:bg-muted rounded-md" aria-label="Remove"><Trash2 className="w-4 h-4"/></button>
            </div>
          ))}
          <div className="flex items-center justify-between pt-2 border-t">
            <div className="text-sm opacity-70">Shipping calculated at checkout</div>
            <div className="flex items-center gap-4">
              <div className="font-medium">Total: {fmt(total)}</div>
              <Button className="rounded-2xl" onClick={() => alert("Connect a real checkout (Snipcart, Lemon Squeezy, Shopify Buy Button, or PayPal).")}>Checkout</Button>
            </div>
          </div>
        </div>
      )}
    </section>
  );
}

