export default function DistortedApertureSite() {
  const [cart, setCart] = useState([]);
  const addToCart = (item) => setCart((c) => {
    const exists = c.find((x) => x.id === item.id);
    return exists ? c : [...c, { ...item, qty: 1 }];
  });
  const remove = (id) => setCart((c) => c.filter((x) => x.id !== id));
  const clear = () => setCart([]);

  return (
    <div className="font-sans text-gray-900">
      <Nav cartCount={cart.length} />
      <Hero />
      <Projects />
      <Prints addToCart={addToCart} />
      <About />
      <Contact />
      <Cart items={cart} remove={remove} clear={clear} />
      <Footer />
    </div>
  );
}
